# AI Orchestrator Environment Configuration
# Copy this file to .env and fill in your values. Both providers speak the
# OpenAI-compatible chat-completions API, so either (or both) can be configured.

# Which provider the agent uses if no capability role is active. The chat REPL
# routes ordinary chat through the planner/orchestrator model.
DEFAULT_PROVIDER=lightning

# Sampling temperature / retry-on-transient-failure count, applied to every
# provider unless overridden per-provider below (LIGHTNING_TEMPERATURE,
# NVIDIA_TEMPERATURE, etc.). Lower temperature = fewer syntax/tool-arg
# mistakes on coding tasks; raise retries if your endpoint cold-starts often.
DEFAULT_TEMPERATURE=0.2
DEFAULT_MAX_RETRIES=2

# Self-hosted OpenAI-compatible gateway (e.g. a Lightning AI GPU instance
# running vLLM/Ollama behind an OpenAI-compatible proxy).
LIGHTNING_BASE_URL=https://your-instance.cloudspaces.litng.ai/v1
LIGHTNING_API_KEY=your_lightning_gateway_key
# Comma-separated list of models the gateway serves. First is the default.
LIGHTNING_MODELS=qwen2.5-coder:14b
# LIGHTNING_TEMPERATURE=0.2
# LIGHTNING_MAX_RETRIES=2

# NVIDIA NIM API (hosted open-source models).
NVIDIA_API_KEY=your_nvidia_api_key
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# NVIDIA_MODELS=openai/gpt-oss-120b,qwen/qwen3-next-80b-a3b-instruct,qwen/qwen2.5-coder-32b-instruct,openai/gpt-oss-20b
# NVIDIA_TEMPERATURE=0.2
# NVIDIA_MAX_RETRIES=2

# Optional capability-role overrides. Defaults prefer NVIDIA for planning,
# repository/documentation reasoning, testing, and deployment; Lightning
# qwen2.5-coder:14b for coding/debugging.
# PLANNER_MODEL=nvidia:openai/gpt-oss-120b
# REPOSITORY_SEARCH_MODEL=nvidia:qwen/qwen3-next-80b-a3b-instruct
# DOCUMENTATION_MODEL=nvidia:qwen/qwen3-next-80b-a3b-instruct
# CODING_MODEL=lightning:qwen2.5-coder:14b
# DEBUGGING_MODEL=lightning:qwen2.5-coder:14b
# TESTING_MODEL=nvidia:openai/gpt-oss-120b
# DEPLOYMENT_MODEL=nvidia:openai/gpt-oss-120b
