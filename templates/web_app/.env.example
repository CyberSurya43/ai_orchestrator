# AI Orchestrator Environment Configuration
# Copy this file to .env and fill in your API keys

# Gemini API Key (required for Gemini agent)
GEMINI_API_KEY=your_gemini_api_key_here

# Codex API Key (required for Codex agent)
CODEX_API_KEY=your_codex_api_key_here

# Ollama Configuration (optional - used for fallback models)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder
