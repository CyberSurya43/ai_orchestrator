# AI Orchestrator Environment Configuration
# Copy this file to .env and customize if needed

# ------------------------------------------------------------------
# CLI Tool Authentication
# ------------------------------------------------------------------
# Each CLI tool manages its own authentication.
# - Codex CLI: uses OPENAI_API_KEY or its own login (run `codex` to set up)
# - Claude Code: uses ANTHROPIC_API_KEY or its own login (run `claude` to set up)
# - Ollama: runs locally, no authentication needed

# ------------------------------------------------------------------
# Ollama Configuration (local model)
# ------------------------------------------------------------------
OLLAMA_MODEL=qwen2.5-coder

# ------------------------------------------------------------------
# Codex CLI Configuration
# ------------------------------------------------------------------
# Approval mode for Codex: full-auto | suggest | ask
CODEX_APPROVAL_MODE=full-auto

# ------------------------------------------------------------------
# Claude Code Configuration
# ------------------------------------------------------------------
# Optional: pin a specific Claude model (leave empty for CLI default)
# CLAUDE_MODEL=claude-sonnet-4
